{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
  
      "rootDir": "./",
      "outDir": "./dist",
  
      "strict": true,
  
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
  
      "resolveJsonModule": true,
      "isolatedModules": true,
  
      "types": ["node"],
      "skipLibCheck": true
    },
    "include": ["**/*.ts"],
    "exclude": ["node_modules", "dist"]
  }